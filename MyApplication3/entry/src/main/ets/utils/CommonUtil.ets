/**
 * йҖҡз”Ёе·Ҙе…·зұ»
 */
export class CommonUtil {
  /**
   * з”ҹжҲҗе”ҜдёҖID
   */
  static generateId(): string {
    return Date.now().toString(36) + Math.random().toString(36).substring(2);
  }

  /**
   * ж јејҸеҢ–ж—¶й—ҙжҲі
   */
  static formatTimestamp(timestamp: number, format: string = 'YYYY-MM-DD HH:mm:ss'): string {
    const date = new Date(timestamp);
    const year = date.getFullYear();
    const month = String(date.getMonth() + 1).padStart(2, '0');
    const day = String(date.getDate()).padStart(2, '0');
    const hours = String(date.getHours()).padStart(2, '0');
    const minutes = String(date.getMinutes()).padStart(2, '0');
    const seconds = String(date.getSeconds()).padStart(2, '0');

    let result = format;
    result = result.replace('YYYY', String(year));
    result = result.replace('MM', month);
    result = result.replace('DD', day);
    result = result.replace('HH', hours);
    result = result.replace('mm', minutes);
    result = result.replace('ss', seconds);
    return result;
  }

  /**
   * иҺ·еҸ–зӣёеҜ№ж—¶й—ҙжҸҸиҝ°
   */
  static getRelativeTime(timestamp: number): string {
    const now = Date.now();
    const diff = now - timestamp;
    const minute = 60 * 1000;
    const hour = 60 * minute;
    const day = 24 * hour;

    if (diff < minute) {
      return 'еҲҡеҲҡ';
    } else if (diff < hour) {
      return `${Math.floor(diff / minute)}еҲҶй’ҹеүҚ`;
    } else if (diff < day) {
      return `${Math.floor(diff / hour)}е°Ҹж—¶еүҚ`;
    } else if (diff < 7 * day) {
      return `${Math.floor(diff / day)}еӨ©еүҚ`;
    } else {
      return CommonUtil.formatTimestamp(timestamp, 'YYYY-MM-DD');
    }
  }

  /**
   * ж јејҸеҢ–йҮ‘йўқ
   */
  static formatAmount(amount: number): string {
    return `ВҘ${amount.toFixed(2)}`;
  }

  /**
   * жүӢжңәеҸ·и„ұж•Ҹ
   */
  static maskPhone(phone: string): string {
    if (!phone || phone.length < 11) return phone;
    return phone.replace(/(\d{3})\d{4}(\d{4})/, '$1****$2');
  }

  /**
   * йӘҢиҜҒжүӢжңәеҸ·
   */
  static isValidPhone(phone: string): boolean {
    return /^1[3-9]\d{9}$/.test(phone);
  }

  /**
   * йӘҢиҜҒйӮ®з®ұ
   */
  static isValidEmail(email: string): boolean {
    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
  }

  /**
   * иҺ·еҸ–зҠ¶жҖҒж–Үжң¬
   */
  static getStatusText(status: string, type: 'club' | 'activity' | 'apply'): string {
    if (type === 'club') {
      if (status === 'pending') return 'еҫ…е®Ўж ё';
      if (status === 'approved') return 'е·ІйҖҡиҝҮ';
      if (status === 'rejected') return 'е·ІжӢ’з»қ';
    } else if (type === 'activity') {
      if (status === 'draft') return 'иҚүзЁҝ';
      if (status === 'pending') return 'еҫ…е®Ўж ё';
      if (status === 'approved') return 'е·ІйҖҡиҝҮ';
      if (status === 'rejected') return 'е·ІжӢ’з»қ';
      if (status === 'ongoing') return 'иҝӣиЎҢдёӯ';
      if (status === 'completed') return 'е·Із»“жқҹ';
      if (status === 'cancelled') return 'е·ІеҸ–ж¶Ҳ';
    } else if (type === 'apply') {
      if (status === 'pending') return 'еҫ…е®Ўж ё';
      if (status === 'approved') return 'е·ІйҖҡиҝҮ';
      if (status === 'rejected') return 'е·ІжӢ’з»қ';
    }
    return status;
  }

  /**
   * иҺ·еҸ–зҠ¶жҖҒйўңиүІ
   */
  static getStatusColor(status: string): string {
    if (status === 'pending') return '#FF9800';
    if (status === 'approved') return '#4CAF50';
    if (status === 'rejected') return '#F44336';
    if (status === 'ongoing') return '#2196F3';
    if (status === 'completed') return '#9E9E9E';
    if (status === 'cancelled') return '#757575';
    if (status === 'draft') return '#9E9E9E';
    return '#757575';
  }

  /**
   * иҺ·еҸ–иҙўеҠЎзұ»еһӢж–Үжң¬
   */
  static getFinanceTypeText(type: string): string {
    return type === 'income' ? 'ж”¶е…Ҙ' : 'ж”ҜеҮә';
  }

  /**
   * иҺ·еҸ–и§’иүІж–Үжң¬
   */
  static getRoleText(role: string): string {
    if (role === 'student') return 'еӯҰз”ҹ';
    if (role === 'leader') return 'зӨҫй•ҝ';
    if (role === 'admin') return 'з®ЎзҗҶе‘ҳ';
    return role;
  }

  /**
   * иҺ·еҸ–зӨҫеӣўеҲҶзұ»еҲ—иЎЁ
   */
  static getClubCategories(): string[] {
    const categories: string[] = [];
    categories.push('з§‘жҠҖзұ»');
    categories.push('ж–Үиүәзұ»');
    categories.push('дҪ“иӮІзұ»');
    categories.push('е…¬зӣҠзұ»');
    categories.push('еӯҰжңҜзұ»');
    categories.push('е®һи·өзұ»');
    categories.push('е…ҙи¶Јзұ»');
    return categories;
  }

  /**
   * иҺ·еҸ–иҙўеҠЎеҲҶзұ»еҲ—иЎЁ
   */
  static getFinanceCategories(type: string): string[] {
    const categories: string[] = [];
    if (type === 'income') {
      categories.push('дјҡиҙ№ж”¶е…Ҙ');
      categories.push('жҙ»еҠЁз»Ҹиҙ№');
      categories.push('иөһеҠ©ж”¶е…Ҙ');
      categories.push('е…¶д»–ж”¶е…Ҙ');
    } else {
      categories.push('жҙ»еҠЁж”ҜеҮә');
      categories.push('зү©иө„йҮҮиҙӯ');
      categories.push('еңәең°з§ҹиөҒ');
      categories.push('е®Јдј иҙ№з”Ё');
      categories.push('е…¶д»–ж”ҜеҮә');
    }
    return categories;
  }

  /**
   * жҲӘж–ӯж–Үжң¬
   */
  static truncateText(text: string, maxLength: number): string {
    if (!text || text.length <= maxLength) return text;
    return text.substring(0, maxLength) + '...';
  }

  /**
   * йҳІжҠ–еҮҪж•°
   */
  static debounce(func: () => void, delay: number): () => void {
    let timeoutId: number | null = null;
    return (): void => {
      if (timeoutId !== null) {
        clearTimeout(timeoutId);
      }
      timeoutId = setTimeout(() => {
        func();
      }, delay);
    };
  }
}
